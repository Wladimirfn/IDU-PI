# Copy this file to .env and fill in your local values.
# Never commit a real .env file.

# Telegram BotFather token.
TELEGRAM_BOT_TOKEN=replace_me

# Your numeric Telegram user id from @userinfobot.
ALLOWED_USER_ID=123456789

# Default folder where Pi runs.
DEFAULT_CWD=/absolute/path/to/your/project

# Optional: semicolon-separated folders the bot may use with /cwd or /new.
# If empty, only DEFAULT_CWD is allowed.
ALLOWED_ROOTS=/absolute/path/to/your/project

# Pi executable. Use "pi" when it is on PATH, or "node" with PI_CLI_JS.
PI_BIN=pi

# Optional: path to Pi CLI JavaScript when PI_BIN=node.
# PI_CLI_JS=/absolute/path/to/pi-coding-agent/dist/cli.js

# Optional Pi CLI flags shared by every persistent RPC child process.
PI_EXTRA_ARGS=--no-skill-registry --no-lens

# Optional selectable Pi agent/model profiles shown by /agents.
# Format: id|Label|optional extra CLI args;id2|Label 2|optional args
PI_AGENT_PROFILES=default|Pi default

# Default profile works directly in the selected project. Non-default profiles use pull-only clones here.
AGENT_WORKSPACE_ROOT=/absolute/path/to/bridge-agents
AGENT_WORKSPACE_MODE=clone
