# NOTE: <repo>/.idu/ is INTENTIONALLY tracked (not gitignored). The .idu/
# directory is governance that travels with the repo, per the Item 3a
# territory model (auditor-approved). See openspec/changes/2026-06-16-
# idu-pi-self-hygiene/proposal.md (the Territory model section).

# Pi/OpenSpec local runtime state, with source templates explicitly allowed
.pi/*
!.pi/extensions/
!.pi/extensions/idu-pi-commands.ts
.pi/extensions/*.backup-*.ts
.pi/extensions/*.backup-*.bak
!.pi/skills/
!.pi/skills/**
# .atl/ holds the skill-registry, an auto-generated per-machine
# index scanned from the user's global skill directories
# (~/.pi/agent/skills, ~/.agents/skills, etc.). It is regenerated
# by `gentle-ai skill-registry refresh --force` and re-appears as
# modified whenever the global set changes, so it must be
# machine-local.
.atl/
openspec/
.mcp/config.local.json

# Project-local base skills are source in this repo
!.agents/
!.agents/skills/
!.agents/skills/**

# Local notes / generated plans
plan.md
subagent-artifacts/
# Inter-AI working notes (scout output, handoff docs, work plans
# the auditor writes for the implementing AI). They are not
# user-facing product docs and must not ship in a fresh clone.
async/
.agent-notes/
birth-real-mcp-test.md

